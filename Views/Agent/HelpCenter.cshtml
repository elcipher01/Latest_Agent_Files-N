@*
=============================================================
  AGENT HELP CENTER
  Agent-facing Help Center page

  Runs INSIDE your existing shared layout.
  No <html>, <head>, <body>, sidebar or topbar here.

  Your shared layout (_AgentLayout.cshtml) must have:
      @RenderSection("Styles",  required: false)   ← inside <head>
      @RenderSection("Scripts", required: false)   ← before </body>
=============================================================
*@

@{
    Layout = "_AgentLayout";
    ViewData["Title"] = "Agent Portal - Help Center";
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
<style>

/* ── strip layout padding ───────────────────────────────────── */
.page-content, .main-content, .content-wrapper, main {
    padding: 0 !important;
    overflow: hidden !important;
}

/* ═══════════════════════════════════════════════════
   ROOT  — 3-column flex shell
═══════════════════════════════════════════════════ */
.hc-shell {
    display: flex;
    width: 100%;
    height: calc(100vh - 60px);  /* 60px = your topbar */
    overflow: hidden;
    font-family: 'Poppins', sans-serif;
    background: #f4f6f8;
    color: #1a1a2e;
}

.hc-shell.resizing,
.hc-shell.resizing * {
    cursor: col-resize !important;
    user-select: none !important;
}

.hc-resizer {
    width: 8px;
    flex-shrink: 0;
    background: #eef0f3;
    border-left: 1px solid #e3e6ea;
    border-right: 1px solid #e3e6ea;
    cursor: col-resize;
    transition: background .15s;
}

.hc-resizer:hover { background: #dfe4ea; }

/* ═══════════════════════════════════════════════════
   COL 1 — TICKET LIST
═══════════════════════════════════════════════════ */
.hc-col-list {
    width: 360px;
    min-width: 300px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #fff;
    border-right: 1px solid #e8e8e8;
}

/* Header */
.hcl-header { padding: 20px 20px 12px; flex-shrink: 0; }
.hcl-title  {
    font-size: 13px; font-weight: 800; letter-spacing: .5px;
    text-transform: uppercase; margin-bottom: 2px;
}
.hcl-sub { font-size: 11px; color: #999; margin-bottom: 16px; }

/* New Ticket btn */
.hcl-new-btn {
    font-family: 'Poppins', sans-serif;
    font-size: 12px; font-weight: 700;
    padding: 9px 20px;
    background: #1a1a2e; color: #fff;
    border: none; border-radius: 8px;
    cursor: pointer; display: flex; align-items: center; gap: 7px;
    transition: opacity .15s; white-space: nowrap;
}
.hcl-new-btn:hover { opacity: .85; }

/* Top row */
.hcl-toprow {
    display: flex; justify-content: space-between;
    align-items: flex-start; margin-bottom: 14px;
}

/* Status tabs */
.hcl-tabs { display: flex; gap: 16px; border-bottom: 2px solid #f0f0f0; margin-bottom: 12px; }
.hcl-tab {
    font-size: 11px; font-weight: 700; letter-spacing: .6px;
    text-transform: uppercase; color: #ccc; cursor: pointer;
    padding-bottom: 9px; border-bottom: 2px solid transparent;
    margin-bottom: -2px; transition: color .15s, border-color .15s; user-select: none;
}
.hcl-tab.active { color: #1a1a2e; border-bottom-color: #1a1a2e; }

/* Type pills */
.hcl-pills { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 10px; }
.hcl-pill {
    font-size: 11px; font-weight: 500; padding: 5px 14px;
    border-radius: 6px; cursor: pointer;
    border: 1px solid #e0e0e0; background: #fff; color: #555;
    transition: all .15s; user-select: none;
}
.hcl-pill.active { background: #1a1a2e; color: #fff; border-color: #1a1a2e; }

/* Search */
.hcl-search {
    display: flex; align-items: center; gap: 7px;
    border: 1px solid #e0e0e0; border-radius: 8px;
    padding: 0 12px; background: #fafafa;
}
.hcl-search i { color: #ccc; font-size: 12px; }
.hcl-search input {
    border: none; background: transparent; outline: none;
    font-family: 'Poppins', sans-serif; font-size: 12px;
    padding: 8px 0; color: #333; width: 100%;
}
.hcl-search input::placeholder { color: #bbb; }

/* Ticket card list */
.hcl-list { flex: 1; overflow-y: auto; }

.hcl-card {
    padding: 14px 20px;
    border-bottom: 1px solid #f5f5f5;
    cursor: pointer;
    display: flex; align-items: flex-start; gap: 12px;
    transition: background .12s; position: relative;
}
.hcl-card:hover { background: #fafbfc; }
.hcl-card.active { background: #f4f4f4; }
.hcl-card.active::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: #1a1a2e; border-radius: 0 3px 3px 0;
}

/* Avatar */
.hcl-av {
    width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; color: #fff; text-transform: uppercase;
}

.hcl-body  { flex: 1; min-width: 0; }
.hcl-row1  { display: flex; align-items: center; gap: 8px; margin-bottom: 2px; flex-wrap: wrap; }
.hcl-name  { font-size: 12.5px; font-weight: 700; color: #1a1a2e; }
.hcl-email { font-size: 10.5px; color: #bbb; }

/* Customer / Seller badge */
.hcl-stype {
    font-size: 9px; font-weight: 800; padding: 2px 7px;
    border-radius: 4px; text-transform: uppercase; letter-spacing: .5px;
}
.hcl-stype.customer { background: #e8f4fc; color: #2980b9; }
.hcl-stype.seller   { background: #fff3e0; color: #e67e22; }

.hcl-subject { font-size: 12px; color: #333; line-height: 1.4; margin-bottom: 6px; }
.hcl-tid     { font-size: 10.5px; color: #bbb; }

/* Status badges (inline in card) */
.hcl-sbadge {
    display: inline-block; font-size: 9.5px; font-weight: 800;
    padding: 3px 9px; border-radius: 5px;
    text-transform: uppercase; letter-spacing: .4px; white-space: nowrap;
}
.hcl-sbadge.urgent  { background: #1a1a2e; color: #fff; }
.hcl-sbadge.open    { background: #e8f8ee; color: #27ae60; }
.hcl-sbadge.pending { background: #fff3e0; color: #e67e22; }
.hcl-sbadge.closed  { background: #f0f0f0; color: #999; }

/* ═══════════════════════════════════════════════════
   COL 2 — CHAT  (center, biggest)
═══════════════════════════════════════════════════ */
.hc-col-chat {
    flex: 1;
    min-width: 420px;
    display: flex; flex-direction: column;
    overflow: hidden;
    background: #f7f8f9;
    border-right: 1px solid #e8e8e8;
}

/* Empty state */
.hcc-empty {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    color: #ccc; padding: 40px; text-align: center;
}
.hcc-empty i { font-size: 54px; margin-bottom: 18px; }
.hcc-empty p { font-size: 13px; font-weight: 500; color: #bbb; line-height: 1.6; }

/* Chat panel */
#hccPanel {
    display: none;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
}

/* Chat topbar */
.hcc-topbar {
    background: #fff;
    padding: 12px 22px;
    border-bottom: 1px solid #efefef;
    display: flex; align-items: center; gap: 12px;
    flex-shrink: 0;
}
.hcc-av {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700; color: #fff;
}
.hcc-name-wrap {}
.hcc-name {
    font-size: 14px; font-weight: 700; display: flex; align-items: center; gap: 8px;
}
.hcc-stype-badge {
    font-size: 9.5px; font-weight: 800; padding: 2px 8px;
    border-radius: 4px; text-transform: uppercase; letter-spacing: .4px;
}
.hcc-stype-badge.customer { background: #e8f4fc; color: #2980b9; }
.hcc-stype-badge.seller   { background: #fff3e0; color: #e67e22; }
.hcc-meta { font-size: 11px; color: #aaa; margin-top: 2px; }

/* ── TIMER ──────────────────────────────────────────────────── */
.hcc-timer-wrap {
    margin-left: auto;
    display: flex; align-items: center; gap: 10px;
}
.hcc-timer {
    display: flex; align-items: center; gap: 6px;
    background: #f4f6f8; border: 1px solid #e0e0e0;
    border-radius: 8px; padding: 6px 13px;
    font-size: 13px; font-weight: 700; color: #1a1a2e;
    font-variant-numeric: tabular-nums;
    min-width: 80px; justify-content: center;
}
.hcc-timer i { font-size: 12px; color: #999; }
.hcc-timer.warning { background: #fff3e0; border-color: #f5c96d; color: #e67e22; }
.hcc-timer.warning i { color: #e67e22; }
.hcc-timer.danger   { background: #fdecea; border-color: #f5c6c6; color: #e74c3c; animation: timerPulse .8s infinite; }
.hcc-timer.danger i { color: #e74c3c; }
@Html.Raw("@keyframes") timerPulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: .6; }
}

/* End Conversation button */
.hcc-end-btn {
    font-family: 'Poppins', sans-serif;
    font-size: 11.5px; font-weight: 700;
    padding: 8px 16px;
    background: #e74c3c; color: #fff;
    border: none; border-radius: 8px;
    cursor: pointer; display: flex; align-items: center; gap: 6px;
    transition: opacity .15s; white-space: nowrap;
}
.hcc-end-btn:hover { opacity: .85; }

/* Topbar icon buttons (transfer, resolve) */
.hcc-icon-btn {
    width: 32px; height: 32px; border-radius: 8px;
    border: 1px solid #e0e0e0; background: #fff;
    cursor: pointer; font-size: 12px; color: #555;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s, color .15s;
}
.hcc-icon-btn:hover { background: #1a1a2e; color: #fff; border-color: #1a1a2e; }

/* Chat messages body */
.hcc-body {
    flex: 1; overflow-y: auto;
    padding: 24px 28px;
    display: flex; flex-direction: column; gap: 18px;
}

/* Date divider */
.hcc-date-div {
    text-align: center; font-size: 10.5px; color: #bbb;
    font-weight: 500; position: relative; margin: 4px 0;
}
.hcc-date-div::before, .hcc-date-div::after {
    content: ''; position: absolute; top: 50%;
    width: 30%; height: 1px; background: #e0e0e0;
}
.hcc-date-div::before { left: 0; }
.hcc-date-div::after  { right: 0; }

/* Bubbles */
.hcc-msg { display: flex; gap: 12px; max-width: 75%; }
.hcc-msg.agent { flex-direction: row-reverse; align-self: flex-end; }
.hcc-msg-av {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff; margin-top: 2px;
}
.hcc-msg-wrap { display: flex; flex-direction: column; }
.hcc-msg.agent .hcc-msg-wrap { align-items: flex-end; }
.hcc-msg-name { font-size: 10.5px; color: #aaa; margin-bottom: 4px; font-weight: 500; }
.hcc-msg-bub {
    padding: 12px 16px; border-radius: 14px;
    font-size: 13px; line-height: 1.65; color: #333;
    background: #efefef;
}
.hcc-msg.agent .hcc-msg-bub {
    background: #1a1a2e; color: #fff;
    border-radius: 14px 14px 2px 14px;
}
.hcc-msg:not(.agent) .hcc-msg-bub { border-radius: 14px 14px 14px 2px; }
.hcc-msg-time { font-size: 10px; color: #bbb; margin-top: 5px; }

/* End-conversation system message */
.hcc-system-msg {
    text-align: center; font-size: 11.5px; color: #aaa;
    font-weight: 500; padding: 8px 20px;
    background: #f0f0f0; border-radius: 20px;
    align-self: center; margin: 4px 0;
}

/* Chat input footer */
.hcc-footer {
    padding: 16px 22px 14px;
    border-top: 1px solid #efefef;
    background: #fff; flex-shrink: 0;
}
.hcc-input-row {
    display: flex; align-items: center; gap: 10px;
    border: 1px solid #e0e0e0; border-radius: 12px;
    padding: 10px 14px; background: #fafafa; margin-bottom: 12px;
}
.hcc-input-row input {
    flex: 1; border: none; background: transparent; outline: none;
    font-family: 'Poppins', sans-serif; font-size: 13px; color: #333;
}
.hcc-input-row input::placeholder { color: #bbb; }
.hcc-send-btn {
    width: 38px; height: 38px; background: #1a1a2e; color: #fff;
    border: none; border-radius: 10px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; flex-shrink: 0; transition: background .15s;
}
.hcc-send-btn:hover { background: #333; }

/* Footer action buttons */
.hcc-footer-btns { display: flex; gap: 8px; }
.hcc-faction {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    font-family: 'Poppins', sans-serif; font-size: 12px; font-weight: 600;
    padding: 10px 16px; border-radius: 8px;
    border: 1px solid #e0e0e0; background: #fff; color: #555;
    cursor: pointer; transition: all .15s; flex: 1;
}
.hcc-faction:hover { background: #f4f6f8; }
.hcc-faction.resolve {
    background: #1a1a2e; color: #fff; border-color: #1a1a2e; flex: 1.5;
}
.hcc-faction.resolve:hover { background: #333; }

/* Disabled input when conversation ended */
.hcc-input-row.ended { opacity: .5; pointer-events: none; }

/* ═══════════════════════════════════════════════════
   COL 3 — TICKET DETAILS  (right sidebar)
═══════════════════════════════════════════════════ */
.hc-col-detail {
    width: 300px;
    min-width: 260px;
    flex-shrink: 0;
    display: flex; flex-direction: column;
    overflow: hidden;
    background: #fff;
}

/* Detail empty */
.hcd-empty {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    color: #ccc; padding: 30px; text-align: center;
}
.hcd-empty i { font-size: 36px; margin-bottom: 12px; }
.hcd-empty p { font-size: 12px; color: #bbb; line-height: 1.6; }

/* Detail panel scroll area */
#hcDetailPanel {
    display: none;
    flex-direction: column;
    height: 100%;
    overflow-y: auto;
}
#hcDetailPanel::-webkit-scrollbar { width: 4px; }
#hcDetailPanel::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 4px; }

/* Label bar */
.hcd-lbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 18px 10px;
    border-bottom: 1px solid #f0f0f0; flex-shrink: 0;
}
.hcd-lbar-title {
    font-size: 10px; font-weight: 800; text-transform: uppercase;
    letter-spacing: .8px; color: #aaa;
}

/* Agent Status Section */
.hcd-agent-status-section {
    padding: 14px 18px 12px;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
}

.hcd-status-label {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .7px;
    color: #bbb;
    margin-bottom: 8px;
    display: block;
}

.hcd-status-wrapper {
    display: flex;
    gap: 8px;
    align-items: center;
}

.hcd-status-dropdown {
    flex: 1;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    padding: 8px 12px;
    color: #333;
    background: #fafafa;
    outline: none;
    cursor: pointer;
    transition: all .15s;
}

.hcd-status-dropdown:hover {
    border-color: #d0d0d0;
    background: #f5f5f5;
}

.hcd-status-dropdown:focus {
    border-color: #1a1a2e;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(26, 26, 46, 0.1);
}

/* Status indicator dot */
.hcd-status-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: background .3s;
}

.hcd-status-indicator.available {
    background: #27ae60;
}

.hcd-status-indicator.break {
    background: #e67e22;
}

.hcd-status-indicator.lunch {
    background: #3498db;
}

.hcd-status-indicator.eos {
    background: #e74c3c;
}

.hcd-pri {
    font-size: 10px; font-weight: 800; padding: 3px 10px;
    border-radius: 20px; text-transform: uppercase; letter-spacing: .4px;
}
.hcd-pri.high   { background: #fdecea; color: #e74c3c; }
.hcd-pri.medium { background: #fff3e0; color: #e67e22; }
.hcd-pri.low    { background: #e8f8ee; color: #27ae60; }
.hcd-pri.urgent { background: #1a1a2e; color: #fff; }

/* Subject + status */
.hcd-subj-blk { padding: 14px 18px 12px; border-bottom: 1px solid #f0f0f0; }
.hcd-subj { font-size: 13px; font-weight: 700; color: #1a1a2e; line-height: 1.4; margin-bottom: 8px; }
.hcd-stat-pill {
    display: inline-block; font-size: 10px; font-weight: 800;
    padding: 3px 10px; border-radius: 5px;
    text-transform: uppercase; letter-spacing: .4px;
}
.hcd-stat-pill.urgent  { background: #1a1a2e; color: #fff; }
.hcd-stat-pill.open    { background: #e8f8ee; color: #27ae60; }
.hcd-stat-pill.pending { background: #fff3e0; color: #e67e22; }
.hcd-stat-pill.closed  { background: #f0f0f0; color: #999; }

/* Sender block */
.hcd-sender {
    display: flex; align-items: center; gap: 10px;
    padding: 13px 18px; border-bottom: 1px solid #f0f0f0;
}
.hcd-sav {
    width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: #fff;
}
.hcd-sname  { font-size: 12.5px; font-weight: 700; }
.hcd-semail { font-size: 11px; color: #aaa; margin-top: 1px; }
.hcd-stype-pill {
    margin-left: auto; font-size: 9.5px; font-weight: 800;
    padding: 3px 8px; border-radius: 4px;
    text-transform: uppercase; letter-spacing: .4px;
}
.hcd-stype-pill.customer { background: #e8f4fc; color: #2980b9; }
.hcd-stype-pill.seller   { background: #fff3e0; color: #e67e22; }

/* Info rows */
.hcd-info-section { border-bottom: 1px solid #f0f0f0; }
.hcd-info-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 9px 18px; border-bottom: 1px solid #fafafa;
}
.hcd-info-key { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #bbb; }
.hcd-info-val { font-size: 12px; font-weight: 700; color: #1a1a2e; text-align: right; }
.hcd-info-val.urgent  { color: #1a1a2e; }
.hcd-info-val.open    { color: #27ae60; }
.hcd-info-val.pending { color: #e67e22; }
.hcd-info-val.closed  { color: #999; }
.hcd-info-val.high    { color: #e74c3c; }
.hcd-info-val.medium  { color: #e67e22; }
.hcd-info-val.low     { color: #27ae60; }

/* Reason block */
.hcd-reason-blk { padding: 14px 18px; border-bottom: 1px solid #f0f0f0; }
.hcd-section-lbl {
    font-size: 10px; font-weight: 800; text-transform: uppercase;
    letter-spacing: .7px; color: #bbb; margin-bottom: 8px;
}
.hcd-reason-txt {
    font-size: 12px; color: #444; line-height: 1.75;
    background: #f7f8fa; border-radius: 8px; padding: 11px 13px;
}

/* Attachments */
.hcd-attach-blk { padding: 12px 18px; border-bottom: 1px solid #f0f0f0; }
.hcd-chips { display: flex; flex-direction: column; gap: 6px; margin-top: 4px; }
.hcd-chip {
    display: flex; align-items: center; gap: 7px;
    background: #f4f6f8; border: 1px solid #e8e8e8; border-radius: 7px;
    padding: 7px 11px; font-size: 11.5px; color: #555; cursor: pointer;
    transition: background .12s;
}
.hcd-chip:hover { background: #eef0f2; }
.hcd-chip i { color: #bbb; font-size: 12px; }

/* Update status */
.hcd-update-blk { padding: 14px 18px; }
.hcd-update-sel {
    width: 100%;
    border: 1px solid #e0e0e0; border-radius: 8px;
    font-family: 'Poppins', sans-serif; font-size: 12px;
    padding: 9px 12px; color: #333; background: #fafafa;
    outline: none; cursor: pointer; margin-bottom: 8px;
}
.hcd-save-btn {
    width: 100%;
    font-family: 'Poppins', sans-serif; font-size: 12px; font-weight: 700;
    padding: 10px; background: #1a1a2e; color: #fff;
    border: none; border-radius: 8px; cursor: pointer; transition: opacity .15s;
}
.hcd-save-btn:hover { opacity: .85; }

/* ── Scrollbars ─────────────────────────────────────────────── */
.hcl-list::-webkit-scrollbar,
.hcc-body::-webkit-scrollbar { width: 4px; }
.hcl-list::-webkit-scrollbar-track,
.hcc-body::-webkit-scrollbar-track { background: transparent; }
.hcl-list::-webkit-scrollbar-thumb,
.hcc-body::-webkit-scrollbar-thumb { background: #ddd; border-radius: 4px; }

</style>
}

@* ══════════════════════════════════════════════════════
   HTML
══════════════════════════════════════════════════════ *@

<div class="hc-shell">

    <!-- ══════ COL 1 — TICKET LIST ══════ -->
    <div class="hc-col-list" id="hcColList">
        <div class="hcl-header">
            <div class="hcl-toprow">
    <div>
        <div class="hcl-title">Today's Record</div>
        <div class="hcl-sub">Queueing and resolved support tickets</div>
    </div>
</div>

<!-- Summary box -->
<div style="display:flex;gap:8px;margin-bottom:14px">
    <div style="flex:1;background:#f7f8fa;border:1px solid #eee;border-radius:10px;padding:10px 12px;text-align:center">
        <div style="font-size:20px;font-weight:800;color:#1a1a2e" id="statQueueing">0</div>
        <div style="font-size:10px;font-weight:600;color:#aaa;text-transform:uppercase;letter-spacing:.5px;margin-top:2px">Queueing</div>
    </div>
    <div style="flex:1;background:#e8f8ee;border:1px solid #b2dfcc;border-radius:10px;padding:10px 12px;text-align:center">
        <div style="font-size:20px;font-weight:800;color:#27ae60" id="statResolved">0</div>
        <div style="font-size:10px;font-weight:600;color:#27ae60;text-transform:uppercase;letter-spacing:.5px;margin-top:2px">Resolved</div>
    </div>
</div>

            <div class="hcl-tabs">
                <div class="hcl-tab active" onclick="hcSetStatus(this,'queueing')">Queueing</div>
                <div class="hcl-tab" onclick="hcSetStatus(this,'resolved')">Resolved Tickets</div>
            </div>

            <div class="hcl-search">
                <i class="fas fa-search"></i>
                <input type="text" id="hclQ" placeholder="Search waiting lines..." oninput="hcFilter()" />
            </div>
        </div>

        <!-- Card list (no table headers) -->
        <div class="hcl-list" id="hclList"></div>
    </div>

    <div class="hc-resizer" id="hcResizerLeft" title="Drag to resize queueing and chat"></div>

    <!-- ══════ COL 2 — CHAT (center, biggest) ══════ -->
    <div class="hc-col-chat" id="hcColChat">

        <div class="hcc-empty" id="hccEmpty">
            <i class="fas fa-comments"></i>
            <p>Click <strong>View</strong> on any ticket<br/>to open the conversation</p>
        </div>

        <div id="hccPanel">

            <!-- Chat topbar: avatar + name + badge · meta · TIMER · End Conversation · icon btns -->
            <div class="hcc-topbar">
                <div class="hcc-av" id="hccAv">—</div>
                <div class="hcc-name-wrap">
                    <div class="hcc-name">
                        <span id="hccName">—</span>
                        <span class="hcc-stype-badge" id="hccStypeBadge">—</span>
                    </div>
                    <div class="hcc-meta" id="hccMeta">—</div>
                </div>

                <div class="hcc-timer-wrap">
                    <!-- 3-minute countdown timer -->
                    <div class="hcc-timer" id="hccTimer">
                        <i class="fas fa-clock"></i>
                        <span id="hccTimerVal">3:00</span>
                    </div>
                    <!-- End Conversation -->
                    <button class="hcc-end-btn" id="hccEndBtn" onclick="hcEndConversation()">
                        <i class="fas fa-phone-slash"></i> End Conversation
                    </button>
                    <!-- Transfer -->
                    <button class="hcc-icon-btn" title="Transfer" onclick="hcTransfer()">
                        <i class="fas fa-share"></i>
                    </button>
                    <!-- Resolve -->
                    <button class="hcc-icon-btn" title="Resolve" onclick="hcResolve()">
                        <i class="fas fa-check"></i>
                    </button>
                </div>
            </div>

            <!-- Messages -->
            <div class="hcc-body" id="hccBody"></div>

            <!-- Input + action buttons -->
            <div class="hcc-footer">
                <div class="hcc-input-row" id="hccInputRow">
                    <input type="text" id="hccChatIn"
                        placeholder="Type a reply to the customer…"
                        onkeydown="if(event.key==='Enter') hcSend()"/>
                    <button class="hcc-send-btn" onclick="hcSend()">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
                <div class="hcc-footer-btns">
                    <button class="hcc-faction" onclick="hcAttach()"><i class="fas fa-paperclip"></i> Attach</button>
                    <button class="hcc-faction" onclick="hcTransfer()"><i class="fas fa-share"></i> Transfer</button>
                    <button class="hcc-faction resolve" onclick="hcResolve()">
                        <i class="fas fa-check-circle"></i> Resolve
                    </button>
                </div>
            </div>

        </div>
    </div>

    <div class="hc-resizer" id="hcResizerRight" title="Drag to resize chat and ticket details"></div>

    <!-- ══════ COL 3 — TICKET DETAILS ══════ -->
    <div class="hc-col-detail" id="hcColDetail">

        <div class="hcd-empty" id="hcdEmpty">
            <i class="fas fa-file-alt"></i>
            <p>Ticket details<br/>will appear here</p>
        </div>

        <div id="hcDetailPanel">

            <!-- Agent Status Section (Top of Ticket Detail) -->
            <div class="hcd-agent-status-section">
                <div class="hcd-status-label">Your Status</div>
                <div class="hcd-status-wrapper">
                    <div class="hcd-status-indicator available" id="statusIndicator"></div>
                    <select class="hcd-status-dropdown" id="agentStatusSelect" onchange="updateAgentStatus()">
                        <option value="available">Available</option>
                        <option value="break">Break</option>
                        <option value="lunch">Lunch</option>
                        <option value="eos">EOS</option>
                    </select>
                </div>
            </div>

            <div class="hcd-lbar">
                <span class="hcd-lbar-title">Ticket Detail</span>
            </div>

            <div class="hcd-subj-blk">
                <div class="hcd-subj" id="hcdSubj">—</div>
            </div>

            <div class="hcd-sender">
                <div class="hcd-sav" id="hcdSav">—</div>
                <div>
                    <div class="hcd-sname"  id="hcdSname">—</div>
                    <div class="hcd-semail" id="hcdSemail">—</div>
                </div>
                <div class="hcd-stype-pill" id="hcdStype">—</div>
            </div>

            <div class="hcd-info-section">
                <div class="hcd-info-row">
                    <span class="hcd-info-key">Date</span>
                    <span class="hcd-info-val" id="hcdIDate">—</span>
                </div>
                <div class="hcd-info-row">
                    <span class="hcd-info-key">Time</span>
                    <span class="hcd-info-val" id="hcdITime">—</span>
                </div>
            </div>

            <div class="hcd-reason-blk">
                <div class="hcd-section-lbl">Reason / Message</div>
                <div class="hcd-reason-txt" id="hcdReason">—</div>
            </div>

            <div class="hcd-attach-blk" id="hcdAttachBlk" style="display:none">
                <div class="hcd-section-lbl">Attachments</div>
                <div class="hcd-chips" id="hcdChips"></div>
            </div>

            <div class="hcd-update-blk">
                <div class="hcd-section-lbl">Update Status</div>
                <select class="hcd-update-sel" id="hcdUpdateSel">
                    <option value="queueing">Queueing</option>
                    <option value="resolved">Resolved Tickets</option>
                </select>
                <button class="hcd-save-btn" onclick="hcSaveStatus()">Save Status</button>
            </div>

        </div>
    </div>

</div>

@section Scripts {
<script>
(function () {

    /* ── helpers ──────────────────────────────────────────────── */
    const COLS = ['#2980b9','#e67e22','#27ae60','#8e44ad','#e74c3c','#16a085','#d35400','#2c3e50'];
    function ac(n) { let h=0; for(let i=0;i<n.length;i++) h=n.charCodeAt(i)+((h<<5)-h); return COLS[Math.abs(h)%COLS.length]; }
    function ini(n) { return n.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(); }
    function cap(s) { return s ? s[0].toUpperCase()+s.slice(1) : ''; }
    function isResolvedStatus(s) { return s === 'closed' || s === 'resolved'; }

    /* ── seed data ────────────────────────────────────────────── */
    let tickets = [
        {
            id:'NH-00421', sender:'Maria Reyes', email:'m.reyes@email.com', stype:'Customer',
            cat:'Orders', priority:'high', status:'urgent',
            subject:'Order not received',
            date:'Mar 17', fullDate:'Mar 17, 2025', time:'9:30 AM',
            reason:'Hi, I placed my order (#ORD-8831) almost two weeks ago and it still has not arrived. The tracking has not updated since March 13. This was a gift and I am very worried. Please help resolve this as soon as possible!',
            attachments:['order_screenshot.png'],
            messages:[
                { from:'Maria Reyes',   role:'user',  text:'Hi, tracking hasn\'t updated since March 13. Please help!', time:'Mar 17 · 9:42 AM' },
                { from:'Agent M. Rivera', role:'agent', text:'Hi Maria! I\'m so sorry to hear that. I\'ve escalated this to our logistics team and will follow up within 2 hours with a full update.', time:'Mar 17 · 10:05 AM' },
            ]
        },
        {
            id:'NH-00418', sender:'Juan Dela Cruz', email:'jdc@email.com', stype:'Customer',
            cat:'Returns', priority:'medium', status:'open',
            subject:'Return request — wrong item shipped',
            date:'Mar 16', fullDate:'Mar 16, 2025', time:'2:15 PM',
            reason:'I received completely the wrong item. I ordered running shoes (size 10) but received a shirt instead. I need to return this and get the correct item delivered.',
            attachments:['wrong_item_photo.jpg','packing_slip.pdf'],
            messages:[
                { from:'Juan Dela Cruz', role:'user', text:'I received the completely wrong item. Photos attached as proof.', time:'Mar 16 · 2:15 PM' },
            ]
        },
        {
            id:'NH-00415', sender:'Ana Santos', email:'anas@email.com', stype:'Customer',
            cat:'Payments', priority:'high', status:'pending',
            subject:'GCash payment debited, order still unpaid',
            date:'Mar 15', fullDate:'Mar 15, 2025', time:'11:05 AM',
            reason:'My GCash was charged ₱2,350 for my order but the platform still shows payment as failed. The money is gone from my account. Please investigate and resolve this immediately.',
            attachments:['gcash_transaction.png'],
            messages:[
                { from:'Ana Santos',    role:'user',  text:'My GCash was charged ₱2,350 but the order shows payment failed. Please refund or confirm the order.', time:'Mar 15 · 11:05 AM' },
                { from:'Agent M. Rivera', role:'agent', text:'Hi Ana, I\'ve raised this with our payments team. They\'ll verify the transaction and respond within 24 hours.', time:'Mar 15 · 11:35 AM' },
            ]
        },
        {
            id:'NH-00410', sender:'Kevin Tan', email:'ktan@email.com', stype:'Customer',
            cat:'Payments', priority:'medium', status:'open',
            subject:'Refund not processed after return',
            date:'Mar 14', fullDate:'Mar 14, 2025', time:'4:50 PM',
            reason:'I returned my item (Return ID: RET-2201) over 8 business days ago and my refund has still not appeared on my credit card. The return was confirmed accepted by your team.',
            attachments:[],
            messages:[
                { from:'Kevin Tan', role:'user', text:'My return was accepted 8 days ago but I still haven\'t received my refund. Reference RET-2201.', time:'Mar 14 · 4:50 PM' },
            ]
        },
        {
            id:'NH-00407', sender:'TrailMasters Store', email:'trailmasters@shop.com', stype:'Seller',
            cat:'Dispute', priority:'high', status:'urgent',
            subject:'Buyer falsely claiming non-delivery',
            date:'Mar 14', fullDate:'Mar 14, 2025', time:'10:20 AM',
            reason:'Buyer #USR-5512 opened a dispute claiming non-receipt. We have courier confirmation of delivery on March 11 at 2:34 PM with a signed receipt. We request the dispute be closed in our favor.',
            attachments:['delivery_receipt.pdf','courier_confirmation.png'],
            messages:[
                { from:'TrailMasters Store', role:'user', text:'We have a signed delivery receipt from March 11. Buyer claim is false. Please close the dispute in our favor.', time:'Mar 14 · 10:20 AM' },
            ]
        },
        {
            id:'NH-00400', sender:'Apex Athletics', email:'apex@athletics.ph', stype:'Seller',
            cat:'Payments', priority:'high', status:'pending',
            subject:'Payout delayed — June settlement missing',
            date:'Mar 12', fullDate:'Mar 12, 2025', time:'9:00 AM',
            reason:'Our June payout of ₱12,400 was supposed to be released on July 5 but has not been received. Our bank details have not changed. Please check the status and release the funds immediately.',
            attachments:['bank_statement.pdf'],
            messages:[
                { from:'Apex Athletics', role:'user',  text:'Our June payout of ₱12,400 has not been received. Please check and release urgently.', time:'Mar 12 · 9:00 AM' },
                { from:'Agent M. Rivera',  role:'agent', text:'Hi Apex! I\'ve flagged this to our finance team. They\'ll review within 1 business day.', time:'Mar 12 · 10:15 AM' },
            ]
        },
        {
            id:'NH-00395', sender:'Lisa Cruz', email:'lcruz@email.com', stype:'Customer',
            cat:'Account', priority:'low', status:'closed',
            subject:'Cannot log in after password reset',
            date:'Mar 10', fullDate:'Mar 10, 2025', time:'3:30 PM',
            reason:'After resetting my password using the forgot-password link, I keep getting an invalid credentials error even though I followed every step correctly.',
            attachments:[],
            messages:[
                { from:'Lisa Cruz',     role:'user',  text:'I reset my password but still can\'t log in. Getting invalid credentials every time.', time:'Mar 10 · 3:30 PM' },
                { from:'Agent M. Rivera', role:'agent', text:'Hi Lisa! I\'ve manually cleared your session cache. Please try logging in now.', time:'Mar 10 · 4:00 PM' },
                { from:'Lisa Cruz',     role:'user',  text:'It worked! Thank you so much!', time:'Mar 11 · 8:55 AM' },
                { from:'Agent M. Rivera', role:'agent', text:'Great! Marking this as resolved. Reach out if anything else comes up.', time:'Mar 11 · 9:00 AM' },
            ]
        },
    ];

    let aStat = 'queueing', selId = null;

    function clamp(v, min, max) { return Math.max(min, Math.min(max, v)); }

    function initResizers() {
        const shell = document.querySelector('.hc-shell');
        const colList = document.getElementById('hcColList');
        const colChat = document.getElementById('hcColChat');
        const colDetail = document.getElementById('hcColDetail');
        const leftHandle = document.getElementById('hcResizerLeft');
        const rightHandle = document.getElementById('hcResizerRight');
        if (!shell || !colList || !colChat || !colDetail || !leftHandle || !rightHandle) return;

        function startDrag(onMove) {
            return function (e) {
                e.preventDefault();
                shell.classList.add('resizing');

                function move(ev) { onMove(ev); }
                function up() {
                    shell.classList.remove('resizing');
                    document.removeEventListener('mousemove', move);
                    document.removeEventListener('mouseup', up);
                }

                document.addEventListener('mousemove', move);
                document.addEventListener('mouseup', up);
            };
        }

        leftHandle.addEventListener('mousedown', startDrag(function (ev) {
            const shellRect = shell.getBoundingClientRect();
            const listMin = 260;
            const detailWidth = colDetail.getBoundingClientRect().width;
            const chatMin = 420;
            const handleSpace = 16;
            const maxList = shellRect.width - detailWidth - chatMin - handleSpace;
            const nextWidth = clamp(ev.clientX - shellRect.left, listMin, maxList);
            colList.style.width = `${nextWidth}px`;
        }));

        rightHandle.addEventListener('mousedown', startDrag(function (ev) {
            const shellRect = shell.getBoundingClientRect();
            const detailMin = 240;
            const listWidth = colList.getBoundingClientRect().width;
            const chatMin = 420;
            const handleSpace = 16;
            const maxDetail = shellRect.width - listWidth - chatMin - handleSpace;
            const nextWidth = clamp(shellRect.right - ev.clientX, detailMin, maxDetail);
            colDetail.style.width = `${nextWidth}px`;
        }));
    }

    /* ── TIMER STATE ──────────────────────────────────────────── */
    let timerInterval   = null;
    let timerSeconds    = 180;   /* 3 minutes */
    let convEnded       = false;

    function startTimer() {
        clearInterval(timerInterval);
        timerSeconds = 180;
        convEnded    = false;
        updateTimerDisplay();
        document.getElementById('hccInputRow').classList.remove('ended');
        document.getElementById('hccEndBtn').disabled = false;
        document.getElementById('hccEndBtn').style.opacity = '1';

        timerInterval = setInterval(function () {
            timerSeconds--;
            updateTimerDisplay();
            if (timerSeconds <= 0) {
                clearInterval(timerInterval);
                timerExpired();
            }
        }, 1000);
    }

    function updateTimerDisplay() {
        const m   = Math.floor(timerSeconds / 60);
        const s   = timerSeconds % 60;
        const str = m + ':' + (s < 10 ? '0' : '') + s;
        const el  = document.getElementById('hccTimerVal');
        const wrap= document.getElementById('hccTimer');
        if (el) el.textContent = str;
        if (wrap) {
            wrap.classList.remove('warning', 'danger');
            if (timerSeconds <= 30) wrap.classList.add('danger');
            else if (timerSeconds <= 60) wrap.classList.add('warning');
        }
    }

    function timerExpired() {
        const el = document.getElementById('hccTimerVal');
        if (el) el.textContent = '0:00';
        appendSystemMsg('⏱ Session time expired — conversation ended automatically.');
        endConv();
    }

    function endConv() {
        convEnded = true;
        clearInterval(timerInterval);
        document.getElementById('hccInputRow').classList.add('ended');
        document.getElementById('hccChatIn').placeholder = 'Conversation has ended.';
        const endBtn = document.getElementById('hccEndBtn');
        if (endBtn) { endBtn.disabled = true; endBtn.style.opacity = '.45'; }
    }

    function appendSystemMsg(text) {
        const body = document.getElementById('hccBody');
        if (!body) return;
        const d = document.createElement('div');
        d.className   = 'hcc-system-msg';
        d.textContent = text;
        body.appendChild(d);
        body.scrollTop = body.scrollHeight;
    }

    window.hcEndConversation = function () {
        if (convEnded) return;
        appendSystemMsg('✓ Conversation ended by Agent M. Rivera.');
        endConv();
    };

    /* ── filter ───────────────────────────────────────────────── */
    function filtered() {
        const q = (document.getElementById('hclQ')?.value || '').toLowerCase().trim();
        return tickets.filter(t => {
            if (aStat === 'resolved' && !isResolvedStatus(t.status)) return false;
            if (aStat === 'queueing' && isResolvedStatus(t.status)) return false;
            if (q && !(
                t.sender.toLowerCase().includes(q) ||
                t.email.toLowerCase().includes(q) ||
                t.subject.toLowerCase().includes(q) ||
                t.id.toLowerCase().includes(q)
            )) return false;
            return true;
        });
    }

    window.hcSetStatus = function (el, v) { document.querySelectorAll('.hcl-tab').forEach(t => t.classList.remove('active'));  el.classList.add('active'); aStat = v; renderList(); };
    window.hcFilter = function () { renderList(); };

    /* ── render card list (NO table, matches screenshot) ─────── */
    function renderList() {
        const rows = filtered();
        const list = document.getElementById('hclList');
        list.innerHTML = '';

        if (!rows.length) {
            list.innerHTML = '<div style="padding:40px;text-align:center;color:#bbb;font-size:13px">No tickets found.</div>';
            return;
        }

        rows.forEach(t => {
            const stc   = t.stype === 'Customer' ? 'customer' : 'seller';
            const color = ac(t.sender);
            const card  = document.createElement('div');
            card.className = 'hcl-card' + (t.id === selId ? ' active' : '');
            card.onclick   = () => openTicket(t.id);
            card.innerHTML = `
                <div class="hcl-av" style="background:${color}">${ini(t.sender)}</div>
                <div class="hcl-body">
                    <div class="hcl-row1">
                        <span class="hcl-name">${t.sender}</span>
                        <span class="hcl-stype ${stc}">${t.stype}</span>
                    </div>
                    <div class="hcl-email" style="font-size:10.5px;color:#bbb;margin-bottom:5px">${t.email}</div>
                    <div class="hcl-subject">${t.subject}</div>
                    <div style="display:flex;align-items:center;gap:8px;margin-top:4px">
                        <span class="hcl-tid">${t.id}</span>
                    </div>
                </div>`;
            list.appendChild(card);
        });
    }

    /* ── open ticket ──────────────────────────────────────────── */
    function openTicket(id) {
        selId = id;
        const t = tickets.find(x => x.id === id);
        renderList();

        /* ── COL 2: CHAT ────────────────────────────────── */
        document.getElementById('hccEmpty').style.display = 'none';
        const cp = document.getElementById('hccPanel');
        cp.style.display = 'flex';
        cp.style.flexDirection = 'column';
        cp.style.height = '100%';

        // topbar
        const cav = document.getElementById('hccAv');
        cav.style.background = ac(t.sender);
        cav.textContent = ini(t.sender);
        document.getElementById('hccName').textContent = t.sender;
        const sb = document.getElementById('hccStypeBadge');
        sb.textContent = t.stype;
        sb.className = `hcc-stype-badge ${t.stype === 'Customer' ? 'customer' : 'seller'}`;
        document.getElementById('hccMeta').textContent = `${t.fullDate}`;

        // messages
        const body = document.getElementById('hccBody');
        body.innerHTML = '';
        const dd = document.createElement('div');
        dd.className   = 'hcc-date-div';
        dd.textContent = t.fullDate;
        body.appendChild(dd);

        t.messages.forEach(m => {
            const isA = m.role === 'agent';
            const w   = document.createElement('div');
            w.className = 'hcc-msg' + (isA ? ' agent' : '');
            w.innerHTML = `
                <div class="hcc-msg-av" style="background:${isA ? '#1a1a2e' : ac(m.from)}">${ini(m.from)}</div>
                <div class="hcc-msg-wrap">
                    <div class="hcc-msg-name">${m.from}</div>
                    <div class="hcc-msg-bub">${m.text}</div>
                    <div class="hcc-msg-time">${m.time}</div>
                </div>`;
            body.appendChild(w);
        });
        body.scrollTop = body.scrollHeight;

        // reset input + restart timer
        document.getElementById('hccChatIn').value = '';
        document.getElementById('hccChatIn').placeholder = 'Type a reply to the customer…';
        document.getElementById('hccInputRow').classList.remove('ended');
        startTimer();

        /* ── COL 3: DETAILS ─────────────────────────────── */
        document.getElementById('hcdEmpty').style.display = 'none';
        const dp = document.getElementById('hcDetailPanel');
        dp.style.display = 'flex';
        dp.style.flexDirection = 'column';

        document.getElementById('hcdSubj').textContent = t.subject;

        const sav = document.getElementById('hcdSav');
        sav.style.background = ac(t.sender);
        sav.textContent = ini(t.sender);
        document.getElementById('hcdSname').textContent  = t.sender;
        document.getElementById('hcdSemail').textContent = t.email;
        const st = document.getElementById('hcdStype');
        st.textContent = t.stype;
        st.className   = `hcd-stype-pill ${t.stype === 'Customer' ? 'customer' : 'seller'}`;

        document.getElementById('hcdIDate').textContent = t.fullDate;
        document.getElementById('hcdITime').textContent = t.time;

        document.getElementById('hcdReason').textContent = t.reason;

        const aBlk  = document.getElementById('hcdAttachBlk');
        const chips = document.getElementById('hcdChips');
        if (t.attachments.length) {
            aBlk.style.display = 'block';
            chips.innerHTML = '';
            t.attachments.forEach(a => {
                const c = document.createElement('div');
                c.className = 'hcd-chip';
                c.innerHTML = `<i class="fas fa-paperclip"></i>${a}`;
                chips.appendChild(c);
            });
        } else {
            aBlk.style.display = 'none';
        }

        document.getElementById('hcdUpdateSel').value = isResolvedStatus(t.status) ? 'resolved' : 'queueing';
    }

    /* ── send ─────────────────────────────────────────────────── */
    window.hcSend = function () {
        if (convEnded) return;
        const inp  = document.getElementById('hccChatIn');
        const text = inp.value.trim();
        if (!text || !selId) return;
        const t   = tickets.find(x => x.id === selId);
        const now = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
        t.messages.push({ from: 'Agent M. Rivera', role: 'agent', text, time: `Now · ${now}` });

        const body = document.getElementById('hccBody');
        const w    = document.createElement('div');
        w.className = 'hcc-msg agent';
        w.innerHTML = `
            <div class="hcc-msg-av" style="background:#1a1a2e">MR</div>
            <div class="hcc-msg-wrap">
                <div class="hcc-msg-name">Agent M. Rivera</div>
                <div class="hcc-msg-bub">${text}</div>
                <div class="hcc-msg-time">Now · ${now}</div>
            </div>`;
        body.appendChild(w);
        body.scrollTop = body.scrollHeight;
        inp.value = '';
    };

    /* ── agent status ─────────────────────────────────────────── */
   /* ── agent status ─────────────────────────────────────────── */
window.updateAgentStatus = function () {
    const statusSelect = document.getElementById('agentStatusSelect');
    const indicator    = document.getElementById('statusIndicator');
    const status       = statusSelect.value;

    indicator.className = `hcd-status-indicator ${status}`;

    fetch('/Agent/UpdateAgentStatus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ agentName: 'Lolett69', status: status })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (!data.success) console.error('Failed to update status:', data.message);
    })
    .catch(function(e) { console.error('Could not reach server:', e); });
};

/* ── load saved status on page init ──────────────────────── */
fetch('/Agent/GetAgentStatus?agentName=Lolett69')
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            const sel = document.getElementById('agentStatusSelect');
            const ind = document.getElementById('statusIndicator');
            if (sel) sel.value = data.status;
            if (ind) ind.className = 'hcd-status-indicator ' + data.status;
        }
    })
    .catch(function(e) { console.error('Could not load agent status:', e); });

    /* ── save status ──────────────────────────────────────────── */
    window.hcSaveStatus = function () {
        if (!selId) return;
        const t = tickets.find(x => x.id === selId);
        t.status = document.getElementById('hcdUpdateSel').value === 'resolved' ? 'resolved' : 'queueing';
        renderList();
        openTicket(selId);
    };

    /* ── resolve ──────────────────────────────────────────────── */
    window.hcResolve = function () {
        if (!selId) return;
        tickets.find(x => x.id === selId).status = 'resolved';
        appendSystemMsg('✓ Ticket marked as Resolved.');
        endConv();
        renderList();
        openTicket(selId);
    };

    /* ── stubs ────────────────────────────────────────────────── */
    window.hcAttach   = function () { alert('Attach — connect to your file upload endpoint.'); };
    window.hcTransfer = function () { alert('Transfer — connect to your agent assignment endpoint.'); };
    window.hcOpenNew  = function () { alert('New Ticket — connect to your ticket creation flow.'); };

    /* ── init ─────────────────────────────────────────────────── */
    initResizers();
    renderList();
    if (tickets.length) openTicket(tickets[0].id);

})();
</script>
}
